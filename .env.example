# ─── Basic 認証 ────────────────────────────────────────────────
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=changeme

# ─── バックエンド ───────────────────────────────────────────────
BACKEND_HOST=localhost
BACKEND_PORT=8000

# ─── フロントエンド（Vite） ─────────────────────────────────────
# 開発サーバーのポート（vite.config.ts の server.port と合わせる）
VITE_PORT=5173

# バックエンド API の URL（フロントエンドから直接叩く場合）
# 開発環境では Vite のプロキシ経由なので不要
# VITE_API_BASE_URL=http://localhost:8000

# ─── nginx ─────────────────────────────────────────────────────
NGINX_PORT=80
