# ─── デフォルト：テキストファイルは LF に統一 ──────────────────
* text=auto eol=lf

# ─── フロントエンド ────────────────────────────────────────────
*.ts        text eol=lf
*.svelte    text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.json      text eol=lf
*.jsonc     text eol=lf

# ─── バックエンド ──────────────────────────────────────────────
*.py        text eol=lf

# ─── C++ ───────────────────────────────────────────────────────
*.cpp       text eol=lf
*.h         text eol=lf
*.c         text eol=lf
CMakeLists.txt text eol=lf

# ─── シェルスクリプト ──────────────────────────────────────────
*.sh        text eol=lf

# ─── ドキュメント・設定 ────────────────────────────────────────
*.md        text eol=lf
*.txt       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf

# ─── SVG（テキストとして管理、差分表示は xml として扱う）───────
*.svg       text eol=lf diff=xml

# ─── バイナリ（差分・マージ・改行変換を無効化）────────────────
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.wasm      binary
*.ttf       binary
*.otf       binary
*.woff      binary
*.woff2     binary
*.pyc       binary

# ─── GitHub 言語統計の調整 ────────────────────────────────────
# emcc 生成ファイルは統計から除外
frontend/src/wasm/pen_engine.js   linguist-generated=true
frontend/src/wasm/pen_engine.wasm linguist-generated=true

# ─── git archive 対象外 ────────────────────────────────────────
.gitignore       export-ignore
.gitattributes   export-ignore
